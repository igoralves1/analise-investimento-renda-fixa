  "formulas": {
    "taxa_bruta_anual": {
      "prefixado": {
        "formula": "i = taxa_anunciada / 100",
        "exemplo": "14,17% → i = 0,1417"
      },
      "pos_fixado_cdi": {
        "formula": "i = (pct_cdi / 100) * cdi_atual",
        "exemplo": "102,5% CDI, CDI=14,65% → i = 1,025 * 0,1465 = 0,15016"
      },
      "hibrido_ipca": {
        "formula": "i = (1 + ipca) * (1 + spread) - 1",
        "exemplo": "IPCA 5,5% + spread 7,20% → i = 1,055 * 1,072 - 1 = 0,13096"
      }
    },

    "prazo_efetivo": {
      "formula": "d = min(data_resgate_desejada, data_vencimento_produto) - data_inicio (em dias corridos)",
      "regra": "Se data_vencimento_produto não informado, usa-se data_resgate_desejada",
      "unidade": "dias corridos (não úteis)"
    },

    "rendimento_bruto_periodo": {
      "formula": "R_bruto = (1 + i)^(d / 365) - 1",
      "parametros": {
        "i": "taxa bruta anual (decimal)",
        "d": "prazo efetivo em dias corridos"
      },
      "nota": "Aproximação usando 365 dias corridos. Para pós-fixado oficial usa-se CDI diário acumulado em 252 dias úteis."
    },

    "aliquota_ir": {
      "formula": "if d <= 180: alpha = 0.225; elif d <= 360: alpha = 0.20; elif d <= 720: alpha = 0.175; else: alpha = 0.15",
      "se_isento_ir": "alpha = 0"
    },

    "aliquota_iof": {
      "formula": "Consultar tabela iof_regressivo. Se d >= 30 ou produto isento_iof: IOF = 0",
      "se_isento_iof": "iof = 0"
    },

    "rendimento_liquido_periodo": {
      "sem_iof": {
        "formula": "R_liq = R_bruto * (1 - alpha)",
        "se_isento_ir": "R_liq = R_bruto"
      },
      "com_iof": {
        "formula": "R_apos_iof = R_bruto * (1 - iof_aliq); R_liq = R_apos_iof * (1 - alpha)",
        "nota": "IOF é aplicado ANTES do IR, sobre o rendimento bruto"
      }
    },

    "taxa_anual_equivalente_liquida": {
      "formula": "i_liq_anual = (1 + R_liq)^(365 / d) - 1",
      "formula_direta_sem_iof": "i_liq_anual = [1 + (1 - alpha) * ((1 + i)^(d/365) - 1)]^(365/d) - 1",
      "descricao": "Esta é a saída principal do aplicativo — a taxa que o usuário vê em destaque"
    },

    "calculo_monetario": {
      "lucro_bruto": "P * R_bruto",
      "iof_valor": "P * R_bruto * iof_aliq (se d < 30 e não isento)",
      "ir_valor": "(P * R_bruto - IOF_valor) * alpha (se não isento IR)",
      "lucro_liquido": "P * R_bruto - IOF_valor - IR_valor",
      "valor_final": "P + lucro_liquido"
    },

    "equivalencia_cdb_lci_lca": {
      "cdb_equivalente_para_lci": {
        "formula": "cdb_pct_cdi_equiv = lci_pct_cdi / (1 - alpha)",
        "descricao": "Qual % CDI o CDB precisa pagar para ter o mesmo retorno líquido que a LCI/LCA"
      },
      "lci_equivalente_para_cdb": {
        "formula": "lci_pct_cdi_equiv = cdb_pct_cdi * (1 - alpha)",
        "descricao": "Qual % CDI a LCI/LCA precisa pagar para ter o mesmo retorno líquido que o CDB"
      }
    }
  },

